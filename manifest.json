{
  "name": "Micro Radar Round TFT",
  "version": "1.0.0",
  "home_assistant_domain": null,
  "new_install_prompt_erase": true,

  "builds": [
    {
      "chipFamily": "ESP32",

      "parts": [
        {
          "path": "firmware/bootloader.bin",
          "offset": "0x1000"
        },
        {
          "path": "firmware/partitions.bin",
          "offset": "0x8000"
        },
        {
          "path": "firmware/boot_app0.bin",
          "offset": "0xe000"
        },
        {
          "path": "firmware/firmware.bin",
          "offset": "0x10000"
        }
      ]
    }
  ]
}